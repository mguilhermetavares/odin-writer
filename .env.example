# Sanity CMS
SANITY_PROJECT_ID=your-project-id
SANITY_DATASET=production
SANITY_TOKEN=your-sanity-editor-token

# AI APIs
ANTHROPIC_API_KEY=your-anthropic-api-key
GROQ_API_KEY=your-groq-api-key

# YouTube (required for source=youtube)
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides
# CLAUDE_MODEL=claude-opus-4-6
# ODIN_WRITER_HOME=/var/odin-writer
# STATE_FILE=/var/odin-writer/state.json
# CACHE_DIR=/var/odin-writer/cache
